          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba-analyze" value="Click Analyze" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="480" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="ba-arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="ba-bmi" target="ba-analyze">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba-pipeline" value="ANALYSIS PIPELINE (4 steps)&#xa;&#xa;Step 1: Detecting Pose...&#xa;  MediaPipe Pose → 33 skeleton landmarks&#xa;&#xa;Step 2: Analyzing Body...&#xa;  Edge detection on image pixels&#xa;  Shoulder-to-hip ratio (V-taper)&#xa;  Elbow spread (mass indicator)&#xa;&#xa;Step 3: Computing Metrics...&#xa;  calculateBodyMetrics() → all scores&#xa;&#xa;Step 4: Generating Results...&#xa;  populateResults() → UI update" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

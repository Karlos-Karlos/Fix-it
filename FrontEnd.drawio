        </mxCell>

        <!-- BOTTOM NAV -->
        <mxCell id="bottomnav-box" value="BOTTOM NAVIGATION BAR (nav-bottom)&#xa;&#xa;• Fixed to bottom of viewport&#xa;• padding-bottom: env(safe-area-inset-bottom)&#xa;• 5 tabs: Home, Workout, Nutrition,&#xa;  Progress, Activity Hub&#xa;• Active tab highlighted with accent&#xa;• Visible on main app screens only" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="90" width="300" height="180" as="geometry" />
        </mxCell>

        <!-- COACH FAB -->
        <mxCell id="coachfab-box" value="COACH FAB (Floating Action Button)&#xa;&#xa;• Fixed bottom-right on all app screens&#xa;• Robot icon button — click to open panel&#xa;• Coach panel slides up as overlay&#xa;• 4 personas: Encouraging, Structured,&#xa;  Humorous, Educational&#xa;• Context-aware (uses current body data)&#xa;• Quick-action buttons&#xa;• POST /api/coach/message" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="90" width="300" height="180" as="geometry" />
        </mxCell>

        <!-- TOAST SYSTEM -->
        <mxCell id="toast-box" value="TOAST NOTIFICATION SYSTEM&#xa;&#xa;4 types:&#xa;• success (green) — action completed&#xa;• error (red/blush) — failure&#xa;• warning (yellow/gold) — caution&#xa;• info (blue) — neutral info&#xa;&#xa;Auto-dismiss after 4 seconds&#xa;Stack up to 3 toasts&#xa;Accessible: role=alert" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="310" width="300" height="180" as="geometry" />
        </mxCell>

        <!-- OFFLINE BANNER -->
        <mxCell id="offline-box" value="OFFLINE BANNER&#xa;&#xa;• div#offline-banner&#xa;• Shown when navigator.onLine = false&#xa;• Text: You are offline — some features may not work&#xa;• Hidden when back online&#xa;• Listens to window online/offline events" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="310" width="300" height="150" as="geometry" />
        </mxCell>

        <!-- CONFIRM MODAL -->
        <mxCell id="confirm-box" value="CONFIRM MODAL&#xa;&#xa;• Generic reusable confirmation dialog&#xa;• Used for: delete scan, logout, etc.&#xa;• [Cancel] and [Confirm] buttons&#xa;• Accessible: focus trap, ESC to close&#xa;• Async: returns Promise&lt;boolean&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="310" width="300" height="150" as="geometry" />
        </mxCell>

        <!-- PREFERENCES MODAL -->
        <mxCell id="prefs-box" value="PREFERENCES MODAL&#xa;&#xa;• Theme picker (5 themes)&#xa;• Units: kg/lbs, cm/ft&#xa;• Step goal&#xa;• Coach persona&#xa;• Saves to localStorage + API&#xa;• PUT /api/users/me/preferences" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="520" width="300" height="160" as="geometry" />
        </mxCell>

        <!-- THEME SYSTEM -->
        <mxCell id="themes-box" value="THEME SYSTEM (5 Themes)&#xa;&#xa;data-theme attribute on &lt;html&gt;&#xa;&#xa;dark    — deep navy (default dark)&#xa;light   — Daybreak (light blue tones)&#xa;midnight — Cosmos (dark navy)&#xa;ocean   — brand navy + electric blue&#xa;lavender — soft purple light&#xa;&#xa;CSS vars for all colors per theme&#xa;initTheme() / applyTheme() in script.js&#xa;Saved per-device in localStorage" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="500" width="300" height="200" as="geometry" />
        </mxCell>

        <!-- PWA -->
        <mxCell id="pwa-box" value="PWA / SERVICE WORKER&#xa;&#xa;• manifest.json linked in &lt;head&gt;&#xa;• sw.js: cache-first strategy&#xa;• Cache versioned (CACHE_NAME)&#xa;• Offline fallback via cache&#xa;• Install banner (iOS):&#xa;  - Shown if standalone not active&#xa;  - Add to Home Screen instructions&#xa;• Install banner (Android):&#xa;  - beforeinstallprompt captured&#xa;  - window.__pwaPrompt stored&#xa;  - [Install App] button trigger" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="500" width="300" height="220" as="geometry" />
        </mxCell>

        <!-- STATE MANAGEMENT -->
        <mxCell id="state-box" value="STATE MANAGEMENT&#xa;&#xa;window.__state (global object):&#xa;• currentScreen, hasImage, imageData&#xa;• analysisResult, landmarks&#xa;• gender, height, weight, bmi&#xa;• fitnessGoal, experienceLevel&#xa;• coachPersona, coachOpen&#xa;• user, accessToken, refreshToken&#xa;• macroTargets, measurements, age&#xa;&#xa;localStorage keys via userKey(base)&#xa;using stable fixit-device-id&#xa;&#xa;apiFetch() — auth + auto-refresh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="740" width="300" height="260" as="geometry" />
        </mxCell>

        <!-- SYNC -->
        <mxCell id="sync-box" value="DATA SYNC FLOW&#xa;&#xa;On login: syncTrackingDataFromServer()&#xa;  Single round-trip: GET /api/sync/all&#xa;  Returns: profile, preferences, gamification,&#xa;    workout history, scans, food logs,&#xa;    sleep, hydration, goalWeight,&#xa;    weightLog, measurements, wearable,&#xa;    achievements, latestPlan, todayFood&#xa;&#xa;Dual-write pattern:&#xa;  All tracking saves → localStorage + API&#xa;  _apiSave() — fire and forget (2 retries)&#xa;&#xa;Token auto-refresh on 401&#xa;Proactive refresh after 10min inactive" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="740" width="320" height="260" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

        <mxCell id="ba-profile" value="Enter Profile&#xa;Height/Weight&#xa;Gender/Goal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="150" y="380" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="ba-arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="ba-quality" target="ba-profile">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba-bmi" value="• Calculate BMI&#xa;• Show BMI category&#xa;• Enable Analyze button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="370" width="200" height="70" as="geometry" />
        </mxCell>

        <!-- LOG SESSION -->
        <mxCell id="ah-log" value="LOG SESSION&#xa;&#xa;POST /wearable/session&#xa;&#xa;Body: {&#xa;  steps, hr_avg,&#xa;  hr_readings (JSONB),&#xa;  calories,&#xa;  active_secs,&#xa;  session_date&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="410" width="200" height="180" as="geometry" />

  <diagram name="AI Coach Flow" id="yFiOPxboHkdlDATXdJah">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="co-title" value="AI COACH FLOW" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="co-bubble" value="COACH FAB (Always Visible — All Screens)&#xa;&#xa;Fixed bottom-right floating button&#xa;Robot icon — click to open panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="375" y="100" width="380" height="70" as="geometry" />
        </mxCell>
        <mxCell id="co-panel" value="COACH PANEL OPENS (slide-up overlay)&#xa;&#xa;Coach: Hi! I am your AI fitness coach.&#xa;Ask me anything about workouts,&#xa;nutrition, or your analysis results!&#xa;&#xa;Quick Actions:&#xa;[My Results] [Workout Tips] [Nutrition] [Explain This]&#xa;&#xa;Persona picker:&#xa;  Encouraging (default) | Structured&#xa;  Humorous | Educational&#xa;  (saves to preferences)&#xa;&#xa;Chat input + [Send] button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="220" width="500" height="260" as="geometry" />
        </mxCell>
        <mxCell id="co-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="co-bubble" target="co-panel">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="co-input" value="User types: How should I train?" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="400" y="530" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="co-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="co-panel" target="co-input">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="co-classify" value="POST /api/coach/message&#xa;&#xa;Request: {&#xa;  message, context: {&#xa;    bodyScore, goal, gender,&#xa;    muscleScore, persona&#xa;  }&#xa;}&#xa;&#xa;Server: coachEngine.js&#xa;  → Classify intent (30 types)&#xa;  → Build response with context&#xa;  → Save to coach_conversations&#xa;  → Return personalized reply&#xa;  → Award +5 Points" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="620" width="500" height="230" as="geometry" />
        </mxCell>
        <mxCell id="co-arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="co-input" target="co-classify">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="co-response" value="PERSONALIZED RESPONSE&#xa;&#xa;Coach (Encouraging): Great question!&#xa;With your Athletic build (score: 72)&#xa;and goal to build muscle, try a&#xa;Push/Pull/Legs split, 4-5 days/week.&#xa;Your muscle tone is at 68% — great potential!&#xa;&#xa;[View Workout Plan] [Ask Follow-up]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="900" width="500" height="170" as="geometry" />
        </mxCell>
        <mxCell id="co-arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="co-classify" target="co-response">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

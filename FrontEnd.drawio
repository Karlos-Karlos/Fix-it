          <mxGeometry x="290" y="700" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="tr-weight" value="WEIGHT LOG&#xa;&#xa;Log: kg entry per day&#xa;POST /tracking/weight-log&#xa;History + trend chart&#xa;GET /tracking/weight-log?days=90&#xa;&#xa;Goal weight:&#xa;PUT /tracking/goal-weight" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- WEARABLE PAIRING -->
        <mxCell id="ah-pair" value="WEARABLE PAIRING&#xa;&#xa;• QRCode.js — generates QR&#xa;• Pair code displayed on screen&#xa;• Device scans QR to pair&#xa;• Sends data via paired session&#xa;• QR library: qrcode@1.5.3" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

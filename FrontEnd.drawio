        <mxCell id="ba-arrow6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="ba-analyze" target="ba-pipeline">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba-results" value="RESULTS GENERATED&#xa;&#xa;• Fitness Index: 7.2/10&#xa;• Body Composition: 72/100 (Athletic)&#xa;• Muscle Tone: 68/100&#xa;• Posture Score: 78/100&#xa;• Symmetry: 82%&#xa;• Visual Age: 28&#xa;&#xa;Zone dots positioned on silhouette&#xa;[Export PDF] [View Breakdown] [Workout]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="275" y="800" width="350" height="160" as="geometry" />
        </mxCell>
        <mxCell id="ba-arrow7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="ba-pipeline" target="ba-results">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

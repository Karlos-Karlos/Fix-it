        <!-- TRACKING LOG TITLE -->
        <mxCell id="tr-title" value="TRACKING LOG SCREENS (Inline within App)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="80" y="640" width="450" height="35" as="geometry" />
        </mxCell>

        <mxCell id="tr-sleep" value="SLEEP LOG&#xa;&#xa;Log: hours + quality&#xa;POST /tracking/sleep&#xa;Chart: 90 days history&#xa;GET /tracking/sleep?days=90" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

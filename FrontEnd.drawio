          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ba-quality" value="IMAGE QUALITY FEEDBACK&#xa;&#xa;Lighting / Contrast / Resolution&#xa;Displayed as coloured progress bars&#xa;&#xa;Guidance: pose, lighting, distance" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

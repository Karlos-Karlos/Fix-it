        <mxCell id="ah-cals" value="CALORIES &amp; ACTIVE TIME&#xa;&#xa;• Total calories burned&#xa;• Active seconds today&#xa;• from wearable_sessions&#xa;• Aggregated: SUM(calories)&#xa;• SUM(active_secs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

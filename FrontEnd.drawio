          <mxGeometry x="450" y="100" width="180" height="45" as="geometry" />
        </mxCell>
        <mxCell id="ah-steps" value="STEP RING&#xa;&#xa;• SVG arc ring (animated)&#xa;• Steps today vs goal&#xa;• Progress %&#xa;• Taps: GET /wearable/today&#xa;• Step goal from preferences" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

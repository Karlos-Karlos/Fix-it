        <!-- HEADER -->
        <mxCell id="header-box" value="FIXED HEADER (iOS Safe Area)&#xa;&#xa;• position: fixed; top: 0&#xa;• padding-top: max(env(safe-area-inset-top), 12px)&#xa;• viewport-fit=cover in meta viewport&#xa;• FiX-it logo + nav-steps dots&#xa;• User menu dropdown (avatar trigger)&#xa;• Admin Dashboard link (admin role only)&#xa;• Preferences modal opener&#xa;• Log Out button" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

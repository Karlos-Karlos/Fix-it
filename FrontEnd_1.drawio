        <mxCell id="co-title" value="AI COACH FLOW" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#1a1a2e;strokeColor=#c9a962;fontColor=#c9a962;" vertex="1" parent="1">
          <mxGeometry x="450" y="20" width="200" height="40" as="geometry" />

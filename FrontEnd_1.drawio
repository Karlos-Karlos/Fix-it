          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="co-response" value="PERSONALIZED RESPONSE&#xa;&#xa;Coach (Encouraging): &quot;Great question! With&#xa;your Athletic build (score: 72) and goal to&#xa;build muscle, I&#39;d recommend 4-5 days per week&#xa;focusing on progressive overload. Your muscle&#xa;tone is at 68% - there&#39;s great potential!&#xa;&#xa;Try a Push/Pull/Legs split. Check the Workout&#xa;screen for your personalized routine!&quot;&#xa;&#xa;[View Workout Plan] [Ask Follow-up]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#7d9a78;strokeColor=#4a6741;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="300" y="960" width="500" height="200" as="geometry" />

        </mxCell>
        <mxCell id="co-classify" value="INTENT CLASSIFICATION&#xa;&#xa;Input: &quot;How should I train?&quot;&#xa;            │&#xa;            ▼&#xa;┌─────────────────────────────────────┐&#xa;│ Classify Intent (ML Model)          │&#xa;│ • workout_general: 0.85 ✓           │&#xa;│ • workout_plan: 0.12                │&#xa;│ • greeting: 0.03                    │&#xa;└─────────────────────────────────────┘&#xa;            │&#xa;            ▼&#xa;Context Variables:&#xa;• bodyScore: 72&#xa;• goal: build-muscle&#xa;• gender: male&#xa;• muscleScore: 68&#xa;• persona: encouraging" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

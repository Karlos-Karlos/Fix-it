        <mxCell id="co-bubble" value="COACH BUBBLE (Always Visible)&#xa;&#xa;        ┌───┐&#xa;        │🤖│ ◄── Click to open&#xa;        └───┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#c9a962;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="375" y="100" width="350" height="90" as="geometry" />
        </mxCell>
        <mxCell id="co-panel" value="COACH PANEL OPENS&#xa;&#xa;┌───────────────────────────────────────────┐&#xa;│ Coach: Hi! I&#39;m your AI fitness coach.    │&#xa;│ Ask me anything about workouts,          │&#xa;│ nutrition, or your analysis results!     │&#xa;└───────────────────────────────────────────┘&#xa;&#xa;Quick Actions:&#xa;[My Results] [Workout Tips] [Nutrition]&#xa;[Explain This]&#xa;&#xa;Persona: [🌟Encouraging ▼]&#xa;         • Encouraging (default)&#xa;         • Structured&#xa;         • Humorous&#xa;         • Educational&#xa;&#xa;┌───────────────────────────────────────────┐&#xa;│ Type your question...             [Send] │&#xa;└───────────────────────────────────────────┘" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">

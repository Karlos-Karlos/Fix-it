# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/Fixit

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string

# Server
PORT=3000
NODE_ENV=development

# Email — Brevo HTTP API (recommended for Railway — no SMTP needed)
# Sign up at brevo.com → Settings → API Keys → Generate key
BREVO_API_KEY=xkeysib-...
EMAIL_FROM=noreply@fixit-app.com

# Email — Generic SMTP (alternative to Gmail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@fixit.app

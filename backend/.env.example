# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/Fixit

# JWT
JWT_SECRET=change-this-to-a-random-64-char-string
JWT_REFRESH_SECRET=change-this-to-another-random-64-char-string

# Server
PORT=3000
NODE_ENV=development

# Email — Gmail (recommended)
# Use a Gmail App Password: Google Account → Security → 2-Step Verification → App Passwords
GMAIL_USER=your-gmail@gmail.com
GMAIL_PASS=xxxx-xxxx-xxxx-xxxx

# Email — Generic SMTP (alternative to Gmail)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM=noreply@fixit.app

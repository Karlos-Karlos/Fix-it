        <!-- ADMIN ENDPOINTS -->
        <mxCell id="ad-title" value="ADMIN ENDPOINTS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#1a1a2e;strokeColor=#c9a962;fontColor=#c9a962;" vertex="1" parent="1">

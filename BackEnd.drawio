  <diagram name="Error Handling and Database" id="IV__m6ja-ZHkPO9hvpDw">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="er-title" value="ERROR TYPES &amp; RESPONSES" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#1a1a2e;strokeColor=#c9a962;fontColor=#c9a962;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="280" height="40" as="geometry" />
        </mxCell>
        <mxCell id="er-400" value="400 Bad Request&#xa;{ error: &quot;VALIDATION_ERROR&quot;,&#xa;  message: &quot;Invalid input data&quot;,&#xa;  details: [{field, error}] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b87351;strokeColor=#8b4513;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="er-401" value="401 Unauthorized&#xa;UNAUTHORIZED | TOKEN_EXPIRED | TOKEN_INVALID&#xa;{ error: &quot;...&quot;, message: &quot;...&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b87351;strokeColor=#8b4513;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="175" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="er-403" value="403 Forbidden&#xa;FORBIDDEN | EMAIL_NOT_VERIFIED&#xa;{ error: &quot;...&quot;, message: &quot;...&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b87351;strokeColor=#8b4513;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="260" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="er-404" value="404 Not Found&#xa;{ error: &quot;NOT_FOUND&quot;,&#xa;  message: &quot;Scan not found&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="345" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="er-409" value="409 Conflict&#xa;{ error: &quot;EMAIL_EXISTS&quot;,&#xa;  message: &quot;Email already registered&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b87351;strokeColor=#8b4513;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="430" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="er-423" value="423 Locked&#xa;{ error: &quot;ACCOUNT_LOCKED&quot;,&#xa;  message: &quot;Too many failed attempts&quot;,&#xa;  retryAfter: 900 }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#b87351;strokeColor=#8b4513;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="515" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="er-429" value="429 Too Many Requests&#xa;{ error: &quot;RATE_LIMITED&quot;,&#xa;  message: &quot;Too many requests&quot;,&#xa;  retryAfter: 60 }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="610" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="er-500" value="500 Internal Server Error&#xa;{ error: &quot;SERVER_ERROR&quot;,&#xa;  message: &quot;Unexpected error&quot; }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#ef4444;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="705" width="250" height="80" as="geometry" />
        </mxCell>
        <!-- DATABASE SCHEMA -->
        <mxCell id="db-title" value="DATABASE SCHEMA (21 Tables)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#1a1a2e;strokeColor=#c9a962;fontColor=#c9a962;" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="300" height="40" as="geometry" />
        </mxCell>
        <mxCell id="db-user-title" value="USER DATA TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="75" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-user1" value="1. users&#xa;2. user_preferences&#xa;3. user_gamification&#xa;4. user_achievements&#xa;5. user_personas_used&#xa;6. workout_sessions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#c9a962;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="100" width="170" height="110" as="geometry" />
        </mxCell>
        <mxCell id="db-user2" value="7. analysis_scans&#xa;8. analysis_results&#xa;9. weekly_plans&#xa;10. food_log&#xa;11. coach_conversations&#xa;12. weekly_challenges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0f3460;strokeColor=#c9a962;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="180" height="110" as="geometry" />
        </mxCell>
        <mxCell id="db-ref-title" value="REFERENCE / LOOKUP TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#7d9a78;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="225" width="230" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-ref" value="13. foods&#xa;14. exercises&#xa;15. achievements&#xa;16. challenges&#xa;17. levels&#xa;18. workout_splits&#xa;19. food_recognition_mappings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#7d9a78;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="250" width="230" height="120" as="geometry" />
        </mxCell>
        <mxCell id="db-sess-title" value="SESSION &amp; AUTH TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#b87351;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="660" y="250" width="190" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-sess" value="20. user_sessions&#xa;21. email_verification_tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#b87351;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="660" y="275" width="190" height="50" as="geometry" />
        </mxCell>
        <!-- Points REWARDS -->
        <mxCell id="xp-title" value="Points REWARDS TABLE" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="400" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="xp-table" value="Action                    Points&#xa;─────────────────────────&#xa;Body Analysis Scan     +30&#xa;Complete Workout       +25&#xa;Complete Challenge     +25&#xa;Save Meal Plan         +10&#xa;Ask Coach Question      +5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#c9a962;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="400" y="425" width="250" height="130" as="geometry" />
        </mxCell>
        <!-- CLIENT ERROR HANDLING CODE -->
        <mxCell id="ch-title" value="CLIENT ERROR HANDLING" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="400" y="575" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ch-code" value="async function apiFetch(endpoint, options) {&#xa;  // AbortController with 15s timeout&#xa;  const ctrl = new AbortController();&#xa;  const timer = setTimeout(() =&gt; ctrl.abort(), 15000);&#xa;  try {&#xa;    // Auto-attach Authorization header&#xa;    const response = await fetch(API_BASE + endpoint, {&#xa;      ...options, signal: ctrl.signal,&#xa;      headers: { Authorization: Bearer token, ... }&#xa;    });&#xa;    if (response.status === 401) {&#xa;      // Auto-refresh token, retry once&#xa;      const ok = await tryRefreshToken();&#xa;      if (ok) return apiFetch(endpoint, options);&#xa;      else handleLogout();&#xa;    }&#xa;    return response;&#xa;  } catch (err) {&#xa;    if (err.name === &#39;AbortError&#39;)&#xa;      throw new Error(&#39;Request timed out&#39;);&#xa;    throw err;&#xa;  } finally { clearTimeout(timer); }&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="400" y="600" width="400" height="300" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

        <mxCell id="an-up-label" value="POST /api/analysis/upload" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="200" height="25" as="geometry" />

          <mxGeometry x="760" y="95" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="an-up-a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="an-up1" target="an-up2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="an-up-a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="an-up2" target="an-up3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="an-sc-label" value="POST /api/analysis/scans" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="500" y="155" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="an-sc1" value="Image URL&#xa;+ Profile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="500" y="180" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="an-sc2" value="Store Scan&#xa;Record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="630" y="180" width="80" height="40" as="geometry" />

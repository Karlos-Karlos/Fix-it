  <diagram name="API - Tracking and Sync" id="TrackingSync_Page">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="ts-title" value="TRACKING &amp; SYNC ENDPOINTS (NEW)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="420" height="40" as="geometry" />
        </mxCell>

        <!-- TRACKING ENDPOINTS -->
        <mxCell id="tr-head" value="TRACKING ROUTES  /api/tracking  (all require auth)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="50" y="80" width="500" height="35" as="geometry" />
        </mxCell>
        <mxCell id="tr-sleep" value="SLEEP LOG&#xa;POST /tracking/sleep&#xa;  Body: { hours, quality, sleep_date? }&#xa;  Upsert on (user_id, sleep_date)&#xa;  quality: poor|fair|good|excellent&#xa;&#xa;GET /tracking/sleep?days=90&#xa;  Returns: [{ date, hours, quality }]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="135" width="220" height="150" as="geometry" />
        </mxCell>
        <mxCell id="tr-hydration" value="HYDRATION LOG&#xa;POST /tracking/hydration&#xa;  Body: { glasses_drunk, log_date? }&#xa;  Upsert on (user_id, log_date)&#xa;  Range: 0–20&#xa;&#xa;GET /tracking/hydration?date=YYYY-MM-DD&#xa;  Returns: { date, glasses_drunk }&#xa;&#xa;GET /tracking/hydration/history?days=30&#xa;  Returns: [{ date, glasses_drunk }]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="135" width="260" height="180" as="geometry" />
        </mxCell>
        <mxCell id="tr-goalwt" value="GOAL WEIGHT&#xa;PUT /tracking/goal-weight&#xa;  Body: { goal_kg, start_kg? }&#xa;  Upsert on (user_id)&#xa;  Range: 30–300 kg&#xa;&#xa;GET /tracking/goal-weight&#xa;  Returns: { goal_kg, start_kg, set_at }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="305" width="220" height="160" as="geometry" />
        </mxCell>
        <mxCell id="tr-weightlog" value="WEIGHT LOG&#xa;POST /tracking/weight-log&#xa;  Body: { weight_kg, log_date? }&#xa;  Upsert on (user_id, log_date)&#xa;  Range: 0–600 kg&#xa;&#xa;GET /tracking/weight-log?days=90&#xa;  Returns: [{ date, weight }]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="290" y="335" width="220" height="160" as="geometry" />
        </mxCell>
        <mxCell id="tr-measurements" value="MEASUREMENTS&#xa;POST /tracking/measurements&#xa;  Body: { chest?, waist?, hips?, arms?, log_date? }&#xa;  At least 1 field required&#xa;  Upsert on (user_id, log_date)&#xa;&#xa;GET /tracking/measurements?days=90&#xa;  Returns: [{ date, chest, waist, hips, arms }]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="490" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="tr-lifts" value="LIFT LOG (Personal Records)&#xa;POST /tracking/lifts&#xa;  Body: { exercise_name, weight_kg, reps, e1rm?, log_date? }&#xa;  Upsert on (user_id, exercise_name, log_date)&#xa;&#xa;GET /tracking/lifts&#xa;  Returns all entries newest-first per exercise" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="515" width="300" height="140" as="geometry" />
        </mxCell>

        <!-- WEARABLE ENDPOINTS -->
        <mxCell id="we-head" value="WEARABLE ROUTES  /api/wearable  (all require auth)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#D45C8C;" vertex="1" parent="1">
          <mxGeometry x="700" y="80" width="420" height="35" as="geometry" />
        </mxCell>
        <mxCell id="we-session" value="POST /wearable/session&#xa;  Body: {&#xa;    steps, hr_avg,&#xa;    hr_readings (JSONB),&#xa;    calories, active_secs,&#xa;    session_date&#xa;  }&#xa;  Validated: wearableSessionSchema&#xa;  Stores to wearable_sessions table&#xa;  Returns: { id, date, steps, hr_avg,&#xa;             calories, active_secs }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="135" width="260" height="190" as="geometry" />
        </mxCell>
        <mxCell id="we-sessions" value="GET /wearable/sessions?limit=30&#xa;  Returns last N sessions&#xa;  (max 100)&#xa;  Fields: id, date, steps,&#xa;    hr_avg, calories, active_secs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="345" width="260" height="120" as="geometry" />
        </mxCell>
        <mxCell id="we-today" value="GET /wearable/today&#xa;  Aggregates today's sessions:&#xa;  COALESCE(SUM(steps), 0)&#xa;  ROUND(AVG(hr_avg))&#xa;  ROUND(SUM(calories))&#xa;  COALESCE(SUM(active_secs), 0)&#xa;  Returns: { total_steps, avg_hr,&#xa;    total_calories, total_active_secs }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="485" width="260" height="170" as="geometry" />
        </mxCell>

        <!-- SYNC ENDPOINT -->
        <mxCell id="sy-head" value="SYNC ROUTE  /api/sync  (requires auth)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=13;fontStyle=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#2EB896;" vertex="1" parent="1">
          <mxGeometry x="50" y="690" width="360" height="35" as="geometry" />
        </mxCell>
        <mxCell id="sy-all" value="GET /sync/all&#xa;&#xa;Single round-trip replacing 14+ individual calls.&#xa;Called by syncTrackingDataFromServer() on login.&#xa;&#xa;Runs 15 parallel DB queries via Promise.all():&#xa;  1. users — profile (gender, height, weight, goal...)&#xa;  2. user_preferences — coach_persona, step_goal, units&#xa;  3. user_gamification — xp, streak, totals&#xa;  4. analysis_scans + results — last 50&#xa;  5. sleep_logs — 365 days&#xa;  6. hydration_logs — 30 days&#xa;  7. goal_weight&#xa;  8. weight_log — 365 days&#xa;  9. measurement_logs — 365 days&#xa; 10. workout_sessions — last 40&#xa; 11. lift_log — all&#xa; 12. wearable_sessions — 90 days&#xa; 13. user_achievements (with titles)&#xa; 14. weekly_plans — latest 1&#xa; 15. food_log — today totals&#xa;&#xa;Returns single JSON object with all 15 keys." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="745" width="430" height="330" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram name="System Architecture" id="0TuEQ8HLTzEwAd2rZcbT">
    <mxGraphModel dx="2393" dy="1136" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="sa-title" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=18;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" value="FiX-it BACKEND ARCHITECTURE" vertex="1">
          <mxGeometry height="50" width="400" x="350" y="20" as="geometry" />
        </mxCell>
        <mxCell id="sa-web" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;" value="WEB CLIENT&#xa;(Browser / PWA)" vertex="1">
          <mxGeometry height="50" width="140" x="280" y="110" as="geometry" />
        </mxCell>
        <mxCell id="sa-admin" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;" value="ADMIN PANEL&#xa;(Screen 10)" vertex="1">
          <mxGeometry height="50" width="140" x="650" y="110" as="geometry" />
        </mxCell>
        <mxCell id="sa-express" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="EXPRESS SERVER (server.js)&#xa;&#xa;• trust proxy (Railway)&#xa;• Security headers (X-Frame, HSTS, etc.)&#xa;• CORS: env FRONTEND_URL + Railway domain&#xa;• express.json 10mb limit&#xa;• generalLimiter (rate limiter)&#xa;• Static /uploads with nosniff headers&#xa;• GET /api/health (DB ping)" vertex="1">
          <mxGeometry height="140" width="280" x="420" y="210" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow1" edge="1" parent="1" source="sa-web" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="sa-express">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow3" edge="1" parent="1" source="sa-admin" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="sa-express">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa-routes" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="ROUTE MODULES (routes/)&#xa;&#xa;/api/auth          → auth.js&#xa;/api/users         → users.js&#xa;/api/analysis      → analysis.js&#xa;/api/workouts      → workouts.js&#xa;/api/nutrition     → nutrition.js&#xa;/api/gamification  → gamification.js&#xa;/api/coach         → coach.js&#xa;/api/admin         → admin.js&#xa;/api/tracking      → tracking.js  (NEW)&#xa;/api/wearable      → wearable.js  (NEW)&#xa;/api/sync          → sync.js      (NEW)" vertex="1">
          <mxGeometry height="220" width="280" x="420" y="390" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow-exp-routes" edge="1" parent="1" source="sa-express" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="sa-routes">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa-middleware" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="MIDDLEWARE&#xa;&#xa;• auth.js — JWT verify + session check&#xa;• rateLimiter.js — 6 limiters&#xa;• errorHandler.js — structured errors&#xa;• validate.js — Joi schema validation&#xa;• multer — file uploads (10MB max)" vertex="1">
          <mxGeometry height="120" width="200" x="20" y="420" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow-mid" edge="1" parent="1" source="sa-routes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="sa-middleware">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa-db" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="DATABASE&#xa;(PostgreSQL)&#xa;&#xa;26+ Tables&#xa;Auto-migrations on start&#xa;runMigrations() in server.js&#xa;&#xa;Connection pool: db.js&#xa;query() / getClient()" vertex="1">
          <mxGeometry height="180" width="220" x="430" y="660" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow-routes-db" edge="1" parent="1" source="sa-routes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" target="sa-db">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa-storage" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="FILE STORAGE&#xa;(Local /uploads/)&#xa;&#xa;• User Photos&#xa;• Multer middleware&#xa;• 10MB max&#xa;• nosniff header" vertex="1">
          <mxGeometry height="150" width="150" x="100" y="700" as="geometry" />
        </mxCell>
        <mxCell id="sa-email" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="EMAIL SERVICE&#xa;(SMTP/Console)&#xa;&#xa;• Verify Emails&#xa;• Password Reset&#xa;• Falls back to console" vertex="1">
          <mxGeometry height="150" width="150" x="760" y="700" as="geometry" />
        </mxCell>
        <mxCell id="sa-ml" parent="1" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" value="CLIENT-SIDE ML&#xa;(Browser Only)&#xa;&#xa;• MediaPipe Pose&#xa;• MobileNet Food ID&#xa;• No server ML" vertex="1">
          <mxGeometry height="150" width="150" x="980" y="500" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow-db-stor" edge="1" parent="1" source="sa-db" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;" target="sa-storage">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="sa-arrow-routes-email" edge="1" parent="1" source="sa-routes" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" target="sa-email">
          <mxGeometry relative="1" as="geometry" />

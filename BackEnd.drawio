        <mxCell id="sa-bcrypt-note" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=8;fontStyle=2;fontSize=10;" value="Password hashing: bcryptjs (12 rounds)&#xa;Replaced: bcrypt → bcryptjs (pure JS, no native build)" vertex="1">
          <mxGeometry height="40" width="300" x="420" y="860" as="geometry" />
        </mxCell>
      </root>

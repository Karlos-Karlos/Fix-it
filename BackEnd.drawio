        <mxCell id="an-up1" value="Image File&#xa;+ Metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="500" y="95" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="an-up2" value="Save to&#xa;Local Disk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="630" y="95" width="80" height="40" as="geometry" />

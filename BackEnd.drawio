        <mxCell id="an-sc3" value="Save Results&#xa;+30 Points" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="760" y="180" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="an-sc-a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="an-sc1" target="an-sc2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="an-sc-a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="an-sc2" target="an-sc3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="an-pipeline" value="SCAN PROCESSING PIPELINE&#xa;1. Create thumbnail (base64 → TEXT column)&#xa;2. Store analysis_scans record&#xa;3. Store analysis_results record&#xa;4. Update gamification (+30 Points)&#xa;5. Check &amp; award achievements&#xa;6. Return complete results" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="250" width="260" height="130" as="geometry" />
        </mxCell>
        <mxCell id="an-other" value="Other Analysis Endpoints:&#xa;GET /api/analysis/scans&#xa;GET /api/analysis/scans/:id&#xa;GET /api/analysis/scans/:id/results&#xa;DELETE /api/analysis/scans/:id&#xa;GET /api/analysis/export/:id (JSON)&#xa;POST /api/analysis/compare (deltas)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="400" width="280" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="API - Workout Nutrition Coach Admin" id="mqTGRFVjuYgwuKH4KXdC">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="wo-title" value="WORKOUT ENDPOINTS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="200" height="35" as="geometry" />
        </mxCell>
        <mxCell id="wo-content" value="GET  /api/workouts/exercises?muscle=&amp;equip=&#xa;GET  /api/workouts/exercises/:id  (with how_to_steps, how_to_tip)&#xa;GET  /api/workouts/splits&#xa;POST /api/workouts/generate  → plan JSON&#xa;POST/GET/PUT/DELETE /api/workouts/plans&#xa;POST /api/workouts/sessions  → +25 Points, streak update&#xa;GET  /api/workouts/sessions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="65" width="380" height="130" as="geometry" />
        </mxCell>
        <mxCell id="nu-title" value="NUTRITION ENDPOINTS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="50" y="220" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="nu-content" value="GET  /api/nutrition/foods?q=  (search)&#xa;GET  /api/nutrition/foods/:id&#xa;GET  /api/nutrition/foods/categories&#xa;POST /api/nutrition/foods/recognize  (MobileNet label → food match)&#xa;POST /api/nutrition/meal-plans/generate  → +10 Points&#xa;POST/GET /api/nutrition/meal-plans&#xa;POST/GET/DELETE /api/nutrition/food-log&#xa;GET  /api/nutrition/food-log/daily?date=YYYY-MM-DD&#xa;&#xa;Meals table: seeded on startup (seedMeals())&#xa;15 template meals: breakfast/lunch/dinner/snack" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="265" width="380" height="200" as="geometry" />
        </mxCell>
        <mxCell id="gm-title" value="GAMIFICATION ENDPOINTS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="50" y="495" width="250" height="35" as="geometry" />
        </mxCell>
        <mxCell id="gm-content" value="GET  /api/gamification/achievements → All achievements&#xa;GET  /api/gamification/user-achievements → Unlocked[]&#xa;GET  /api/gamification/challenges → All challenges&#xa;GET  /api/gamification/user-challenges → Active weekly&#xa;POST /api/gamification/refresh-challenges (weekly reset)&#xa;GET  /api/gamification/levels → Level thresholds&#xa;&#xa;Step achievements (NEW via seed):&#xa;  first-steps, steps-5k, steps-goal, steps-goal-7" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="540" width="380" height="170" as="geometry" />
        </mxCell>
        <!-- COACH -->
        <mxCell id="co-title" value="COACH ENDPOINTS" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="550" y="20" width="220" height="35" as="geometry" />
        </mxCell>
        <mxCell id="co-msg1" value="User Msg&#xa;+ Context&#xa;+ Persona" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="500" y="70" width="80" height="50" as="geometry" />
        </mxCell>
        <mxCell id="co-msg2" value="Classify&#xa;Intent" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="630" y="75" width="80" height="40" as="geometry" />
        </mxCell>
        <mxCell id="co-msg3" value="Generate&#xa;Response&#xa;+5 Points&#xa;Save Log" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry x="760" y="65" width="80" height="55" as="geometry" />
        </mxCell>
        <mxCell id="co-msg-a1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="co-msg1" target="co-msg2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="co-msg-a2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="co-msg2" target="co-msg3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="co-other" value="GET /api/coach/conversations&#xa;GET /api/coach/personas&#xa;POST /api/coach/message  (main endpoint)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="145" width="280" height="60" as="geometry" />
        </mxCell>
        <!-- ADMIN -->
        <mxCell id="ad-title" value="ADMIN ENDPOINTS  (role=admin required)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#D45C8C;fontColor=#D45C8C;" vertex="1" parent="1">
          <mxGeometry x="500" y="240" width="350" height="35" as="geometry" />
        </mxCell>
        <mxCell id="ad-content" value="GET    /api/admin/users             → List users (paginated)&#xa;GET    /api/admin/users/:id         → View user details&#xa;PUT    /api/admin/users/:id         → Update role/verified&#xa;DELETE /api/admin/users/:id         → Remove user&#xa;POST   /api/admin/users/:id/unlock  → Unlock account&#xa;POST   /api/admin/users/:id/lock    → Lock account&#xa;GET    /api/admin/stats             → Dashboard statistics&#xa;&#xa;CRUD endpoints:&#xa;  /admin/foods  /admin/exercises&#xa;  /admin/achievements  /admin/challenges  /admin/splits&#xa;&#xa;Requires: auth + isAdmin middleware + adminLimiter (60/15min)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="285" width="380" height="210" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Database Schema" id="DB_Schema_Page">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="db-title" value="DATABASE SCHEMA (26+ Tables)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="380" y="20" width="320" height="40" as="geometry" />
        </mxCell>

        <!-- USER DATA -->
        <mxCell id="db-user-title" value="USER DATA TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#2E96D4;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="75" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-user1" value="1. users&#xa;   id, email, password_hash, display_name,&#xa;   role, email_verified, failed_attempts,&#xa;   locked_until, gender, height, weight,&#xa;   age_range, fitness_goal, avatar_url&#xa;&#xa;2. user_preferences&#xa;   user_id, coach_persona,&#xa;   step_goal (NEW), weight_unit (NEW),&#xa;   height_unit (NEW)&#xa;&#xa;3. user_gamification&#xa;   user_id, total_xp, current_streak,&#xa;   best_streak, total_workouts, total_analyses&#xa;&#xa;4. user_achievements&#xa;5. user_personas_used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="100" width="280" height="270" as="geometry" />
        </mxCell>

        <!-- TRACKING TABLES (NEW) -->
        <mxCell id="db-track-title" value="TRACKING TABLES (NEW)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#2EB896;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="370" y="75" width="220" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-track" value="6. sleep_logs&#xa;   user_id, sleep_date (UNIQUE per user),&#xa;   hours NUMERIC(4,2), quality VARCHAR(20)&#xa;&#xa;7. hydration_logs&#xa;   user_id, log_date (UNIQUE per user),&#xa;   glasses_drunk INTEGER&#xa;&#xa;8. goal_weight&#xa;   user_id (UNIQUE), goal_kg, start_kg&#xa;&#xa;9. weight_log&#xa;   user_id, log_date (UNIQUE per user),&#xa;   weight_kg NUMERIC(5,2)&#xa;&#xa;10. measurement_logs&#xa;    user_id, log_date (UNIQUE per user),&#xa;    chest, waist, hips, arms NUMERIC(5,2)&#xa;&#xa;11. lift_log&#xa;    user_id, exercise_name, log_date&#xa;    (UNIQUE per user+exercise+date),&#xa;    weight_kg, reps, e1rm NUMERIC(6,2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="370" y="100" width="280" height="340" as="geometry" />
        </mxCell>

        <!-- ACTIVITY TABLES (NEW) -->
        <mxCell id="db-act-title" value="ACTIVITY / WEARABLE (NEW)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#D45C8C;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="700" y="75" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-act" value="12. wearable_sessions&#xa;    user_id, session_date, steps,&#xa;    hr_avg, hr_readings JSONB,&#xa;    calories, active_secs&#xa;&#xa;13. workout_sessions&#xa;    user_id, workout_date,&#xa;    workout_type, duration_minutes,&#xa;    notes, xp_earned&#xa;&#xa;14. analysis_scans&#xa;    user_id, scan_date, image_url TEXT,&#xa;    thumbnail_url TEXT (was VARCHAR 500)&#xa;&#xa;15. analysis_results&#xa;    scan_id, body_score, muscle_score,&#xa;    posture_score, fitness_index, etc." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="100" width="280" height="270" as="geometry" />
        </mxCell>

        <!-- CONTENT TABLES -->
        <mxCell id="db-content-title" value="CONTENT / REFERENCE TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#2E96D4;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="395" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-content" value="16. foods&#xa;17. exercises  (+ how_to_steps JSONB, how_to_tip TEXT — NEW)&#xa;18. achievements  (+ 4 step achievements — NEW)&#xa;19. challenges&#xa;20. levels&#xa;21. workout_splits&#xa;22. food_recognition_mappings&#xa;23. weekly_plans  (plan_data JSONB)&#xa;24. food_log&#xa;25. meals  (seeded on startup — NEW)&#xa;26. coach_conversations&#xa;27. weekly_challenges" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="420" width="400" height="200" as="geometry" />
        </mxCell>

        <!-- SESSION / AUTH TABLES -->
        <mxCell id="db-sess-title" value="SESSION &amp; AUTH TABLES" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#D45C8C;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="500" y="395" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="db-sess" value="28. user_sessions&#xa;    access_token_hash, refresh_token_hash,&#xa;    is_revoked, expires_at&#xa;    (indexed on both token hashes)&#xa;&#xa;29. email_verification_tokens&#xa;    token_hash, type, expires_at, used" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="420" width="280" height="140" as="geometry" />
        </mxCell>

        <!-- INDEXES -->
        <mxCell id="db-idx" value="KEY INDEXES (added in migrations)&#xa;&#xa;idx_sleep_logs_user_id&#xa;idx_hydration_logs_user_id&#xa;idx_weight_log_user_id&#xa;idx_measurement_logs_user_id&#xa;idx_lift_log_user_id&#xa;idx_wearable_sessions_user_id&#xa;idx_coach_conversations_user_id&#xa;idx_workout_sessions_user_id&#xa;idx_analysis_scans_user_id&#xa;idx_food_log_user_id&#xa;idx_user_sessions_access_token_hash&#xa;idx_user_sessions_refresh_token_hash&#xa;idx_user_sessions_user_id" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="830" y="395" width="240" height="220" as="geometry" />
        </mxCell>

        <!-- POINTS TABLE -->
        <mxCell id="xp-table" value="Points REWARDS&#xa;&#xa;Action                    Points&#xa;Body Analysis Scan     +30&#xa;Complete Workout       +25&#xa;Complete Challenge     +25&#xa;Save Meal Plan         +10&#xa;Ask Coach Question      +5" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="50" y="650" width="250" height="140" as="geometry" />
        </mxCell>

        <!-- MIGRATION NOTE -->
        <mxCell id="mig-note" value="AUTO-MIGRATIONS (runMigrations() on startup)&#xa;&#xa;• Runs 001_init.sql on fresh DB (Railway)&#xa;• Safe ALTER TABLE IF NOT EXISTS for each column&#xa;• Idempotent: safe to restart&#xa;• bcryptjs (pure JS) replaces bcrypt (native)&#xa;• Admin account ensured via ADMIN_EMAIL env var" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="350" y="680" width="400" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Data Flow and Gamification" id="ZbZQ1DeOmvU1OgZD3563">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="df-title" value="DATA FLOW DIAGRAM" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="250" height="40" as="geometry" />
        </mxCell>
        <mxCell id="df-user" value="USER ACTIONS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="100" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="df-analyze" value="ANALYZE&#xa;BODY" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="100" y="200" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="df-workout" value="WORKOUT&#xa;COMPLETE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="350" y="200" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="df-nutrition" value="NUTRITION&#xa;LOG" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="575" y="200" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="df-tracking" value="TRACKING&#xa;(Sleep/Water/Weight)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="790" y="200" width="120" height="50" as="geometry" />
        </mxCell>
        <mxCell id="df-wearable" value="WEARABLE&#xa;SESSION" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#D45C8C;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="980" y="200" width="100" height="50" as="geometry" />
        </mxCell>
        <mxCell id="df-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-user" target="df-analyze"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-user" target="df-workout"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-user" target="df-nutrition"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-user" target="df-tracking"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-user" target="df-wearable"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-api" value="BACKEND API (Express)&#xa;&#xa;1. Authenticate (JWT validation + session check)&#xa;2. Validate input data (Joi schemas)&#xa;3. Process business logic&#xa;4. Update PostgreSQL (dual-write pattern)&#xa;5. Trigger side effects (gamification, achievements)&#xa;6. Return response&#xa;&#xa;Rate limiting: 6 limiters (general, auth, upload, etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="310" width="650" height="150" as="geometry" />
        </mxCell>
        <mxCell id="df-arrow6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-analyze" target="df-api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-workout" target="df-api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow8" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-nutrition" target="df-api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow9" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-tracking" target="df-api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-wearable" target="df-api"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-db" value="PRIMARY DATABASE (Postgres)&#xa;&#xa;User + tracking data&#xa;Gamification state&#xa;Workout + food logs&#xa;Wearable sessions" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="520" width="160" height="150" as="geometry" />
        </mxCell>
        <mxCell id="df-storage" value="FILE STORAGE&#xa;(/uploads/)&#xa;&#xa;Photos&#xa;Multer 10MB" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="430" y="520" width="150" height="120" as="geometry" />
        </mxCell>
        <mxCell id="df-cache" value="RATE LIMITING&#xa;(In-Memory)&#xa;&#xa;express-rate-limit&#xa;6 limiters&#xa;No Redis needed" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="520" width="150" height="120" as="geometry" />
        </mxCell>
        <mxCell id="df-arrow11" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-api" target="df-db"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow12" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-api" target="df-storage"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="df-arrow13" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="df-api" target="df-cache"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- GAMIFICATION TRIGGER FLOW -->
        <mxCell id="gf-title" value="GAMIFICATION TRIGGER FLOW" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="350" y="720" width="350" height="40" as="geometry" />
        </mxCell>
        <mxCell id="gf-action" value="USER ACTION&#xa;(Workout, Scan,&#xa;Steps, etc.)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2E96D4;fontColor=#e8e8e8;" vertex="1" parent="1">
          <mxGeometry x="450" y="800" width="150" height="55" as="geometry" />
        </mxCell>
        <mxCell id="gf-engine" value="GAMIFICATION ENGINE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#2EB896;fontColor=#e8e8e8;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="450" y="895" width="150" height="40" as="geometry" />
        </mxCell>
        <mxCell id="gf-arrow1" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-action" target="gf-engine"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf-xp" value="AWARD Points&#xa;&#xa;+30 = analysis&#xa;+25 = workout&#xa;+25 = challenge&#xa;+10 = meal plan&#xa; +5 = coach Q&#xa;+25 = step ach." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="170" y="970" width="130" height="130" as="geometry" />

  <diagram name="Authentication Flow" id="rPKZjCzCa3QFEqpbF_s8">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="3000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="af-title" value="AUTHENTICATION FLOW" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#1a1a2e;strokeColor=#c9a962;fontColor=#c9a962;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="300" height="40" as="geometry" />
        </mxCell>
        <!-- REGISTRATION -->
        <mxCell id="af-reg-title" value="REGISTRATION" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="425" y="80" width="150" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-reg-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  POST /auth/register                          │&#xa;  │  { email, password, display_name }            │&#xa;  │  Password: min 8, upper+lower+num+special     │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. Validate email fmt │&#xa;  │                              │ 2. Check if exists    │&#xa;  │                              │    → 409 if duplicate │&#xa;  │                              │ 3. bcrypt hash (12r)  │&#xa;  │                              │ 4. Create user record │&#xa;  │                              │    email_verified=F   │&#xa;  │                              │ 5. Gen verify token   │&#xa;  │                              │    SHA256 → store     │&#xa;  │                              │    expires: 24 hours  │&#xa;  │                              │ 6. Send verify email  │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  { message: &quot;Check your email to verify       │&#xa;  │    your account&quot; }                             │&#xa;  │                                               │&#xa;  ▼                                               │&#xa;Show Email Verify screen (0C) · NO JWT issued" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="110" width="700" height="350" as="geometry" />
        </mxCell>
        <!-- LOGIN -->
        <mxCell id="af-log-title" value="LOGIN (with Security Checks)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="480" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-log-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  POST /auth/login                             │&#xa;  │  { email, password }                          │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. Find user by email │&#xa;  │                              │ 2. Check locked_until │&#xa;  │                              │    → 423 if locked    │&#xa;  │                              │ 3. bcrypt.compare()   │&#xa;  │                              │    If fail:           │&#xa;  │                              │    failed_attempts++  │&#xa;  │                              │    If ≥5: lock 30min  │&#xa;  │                              │    → 401 invalid      │&#xa;  │                              │ 4. Check email_verified│&#xa;  │                              │    → 403 if false     │&#xa;  │                              │ 5. Reset fail counter │&#xa;  │                              │ 6. Generate JWT pair  │&#xa;  │                              │    access: 15 min     │&#xa;  │                              │    refresh: 7 days    │&#xa;  │                              │ 7. Create session     │&#xa;  │                              │    store token hashes │&#xa;  │                              │ 8. Update last_login  │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  { accessToken, refreshToken, user }          │" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="510" width="700" height="400" as="geometry" />
        </mxCell>
        <!-- PROTECTED REQUEST -->
        <!-- EMAIL VERIFICATION -->
        <mxCell id="af-ver-title" value="EMAIL VERIFICATION" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="930" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-ver-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  POST /auth/verify-email                      │&#xa;  │  { email, code } (6-digit from email)         │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. SHA256 hash token  │&#xa;  │                              │ 2. Find by hash       │&#xa;  │                              │ 3. Check type =       │&#xa;  │                              │    email_verification │&#xa;  │                              │ 4. Check not expired  │&#xa;  │                              │    (24h limit)        │&#xa;  │                              │ 5. Check not used     │&#xa;  │                              │ 6. Set email_verified  │&#xa;  │                              │    = true             │&#xa;  │                              │ 7. Set email_verified  │&#xa;  │                              │    _at = NOW()        │&#xa;  │                              │ 8. Mark token used    │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  { message: &quot;Email verified&quot; }                │&#xa;  │                                               │&#xa;  ▼                                               │&#xa;Redirect to Login screen" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="960" width="700" height="370" as="geometry" />
        </mxCell>
        <!-- FORGOT PASSWORD -->
        <mxCell id="af-forgot-title" value="FORGOT PASSWORD" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="1350" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-forgot-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  POST /auth/forgot-password                   │&#xa;  │  { email }                                    │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. Find user by email │&#xa;  │                              │ 2. If exists:         │&#xa;  │                              │    Gen reset token    │&#xa;  │                              │    SHA256 → store     │&#xa;  │                              │    expires: 1 hour    │&#xa;  │                              │    Send reset email   │&#xa;  │                              │ 3. If not exists:     │&#xa;  │                              │    Do nothing         │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  200 { message: &quot;If email exists...&quot; }        │&#xa;  │  (ALWAYS 200 to prevent email enumeration)    │" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="1380" width="700" height="300" as="geometry" />
        </mxCell>
        <!-- RESET PASSWORD -->
        <mxCell id="af-reset-title" value="RESET PASSWORD" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="1700" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-reset-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  POST /auth/reset-password                    │&#xa;  │  { token, new_password }                      │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. SHA256 hash token  │&#xa;  │                              │ 2. Find by hash       │&#xa;  │                              │ 3. Check type =       │&#xa;  │                              │    password_reset     │&#xa;  │                              │ 4. Check not expired  │&#xa;  │                              │    (1h limit)         │&#xa;  │                              │ 5. Check not used     │&#xa;  │                              │ 6. bcrypt hash new pw │&#xa;  │                              │    (12 rounds)        │&#xa;  │                              │ 7. Update password    │&#xa;  │                              │ 8. Revoke ALL user    │&#xa;  │                              │    sessions           │&#xa;  │                              │ 9. Mark token used    │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  { message: &quot;Password reset successfully&quot; }   │&#xa;  │                                               │&#xa;  ▼                                               │&#xa;Redirect to Login screen (user must re-login)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="1730" width="700" height="380" as="geometry" />
        </mxCell>
        <!-- PROTECTED REQUEST -->
        <mxCell id="af-prot-title" value="PROTECTED REQUEST" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="400" y="2130" width="200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-prot-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  GET /api/users/me                            │&#xa;  │  Authorization: Bearer &lt;accessToken&gt;          │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. Extract token      │&#xa;  │                              │ 2. Verify JWT sig     │&#xa;  │                              │ 3. Check expiration   │&#xa;  │                              │ 4. Check session not  │&#xa;  │                              │    revoked (is_revoked│&#xa;  │                              │    = false)           │&#xa;  │                              │ 5. Get user from DB   │&#xa;  │                              │ 6. Attach to request  │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  { user data }                                │" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="2160" width="700" height="280" as="geometry" />
        </mxCell>
        <!-- TOKEN REFRESH -->
        <mxCell id="af-ref-title" value="TOKEN REFRESH" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontStyle=1;fontColor=#c9a962;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="420" y="2460" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="af-ref-box" value="Client                                          Server&#xa;  │                                               │&#xa;  │  Access token expired (401)                   │&#xa;  │                                               │&#xa;  │  POST /auth/refresh                           │&#xa;  │  { refreshToken }                             │&#xa;  │──────────────────────────────────────────────►│&#xa;  │                                               │&#xa;  │                              ┌────────────────┴──────┐&#xa;  │                              │ 1. Hash refresh token │&#xa;  │                              │ 2. Find session by    │&#xa;  │                              │    refresh_token_hash │&#xa;  │                              │ 3. Check is_revoked   │&#xa;  │                              │    = false            │&#xa;  │                              │ 4. Check not expired  │&#xa;  │                              │ 5. Generate new JWT   │&#xa;  │                              │ 6. Update session     │&#xa;  │                              └────────────────┬──────┘&#xa;  │                                               │&#xa;  │◄──────────────────────────────────────────────│&#xa;  │  { newAccessToken }                           │&#xa;  │                                               │&#xa;  ▼                                               │&#xa;Retry original request with new token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#16213e;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="150" y="2490" width="700" height="340" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

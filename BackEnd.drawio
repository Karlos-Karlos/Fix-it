  <diagram name="Error Handling and Auth Flow" id="IV__m6ja-ZHkPO9hvpDw">
    <mxGraphModel dx="1434" dy="780" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1169" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="er-title" value="ERROR TYPES &amp; RESPONSES" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="50" y="20" width="280" height="35" as="geometry" />
        </mxCell>
        <mxCell id="er-400" value="400 Bad Request&#xa;{ error: VALIDATION_ERROR,&#xa;  details: [{field, error}] }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="250" height="70" as="geometry" />
        </mxCell>
        <mxCell id="er-401" value="401 Unauthorized&#xa;UNAUTHORIZED | TOKEN_EXPIRED&#xa;| TOKEN_INVALID" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="155" width="250" height="65" as="geometry" />
        </mxCell>
        <mxCell id="er-403" value="403 Forbidden&#xa;FORBIDDEN | EMAIL_NOT_VERIFIED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="235" width="250" height="55" as="geometry" />
        </mxCell>
        <mxCell id="er-404" value="404 Not Found&#xa;{ error: NOT_FOUND,&#xa;  message: Scan not found }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="305" width="250" height="65" as="geometry" />
        </mxCell>
        <mxCell id="er-409" value="409 Conflict&#xa;{ error: EMAIL_EXISTS }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="385" width="250" height="55" as="geometry" />
        </mxCell>
        <mxCell id="er-423" value="423 Locked&#xa;{ error: ACCOUNT_LOCKED,&#xa;  retryAfter: 900 }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="455" width="250" height="65" as="geometry" />
        </mxCell>
        <mxCell id="er-429" value="429 Too Many Requests&#xa;{ error: RATE_LIMITED,&#xa;  retryAfter: 60 }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="535" width="250" height="65" as="geometry" />
        </mxCell>
        <mxCell id="er-500" value="500 Internal Server Error&#xa;{ error: SERVER_ERROR }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#0C1420;strokeColor=#ef4444;fontColor=#e8e8e8;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="615" width="250" height="55" as="geometry" />
        </mxCell>

        <!-- AUTH FLOW SEQUENCE -->
        <mxCell id="af-title" value="AUTHENTICATION SEQUENCE" style="rounded=1;whiteSpace=wrap;html=1;fontSize=14;fontStyle=1;fillColor=#0C1420;strokeColor=#2E96D4;fontColor=#2E96D4;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="300" height="35" as="geometry" />
        </mxCell>
        <mxCell id="af-login-box" value="LOGIN FLOW&#xa;&#xa;Client → POST /auth/login { email, password }&#xa;&#xa;Server:&#xa;  1. Find user by email&#xa;  2. Check locked_until → 423 if locked&#xa;  3. bcryptjs.compare() → fail → failed_attempts++&#xa;     If ≥5: lock 30min → 401&#xa;  4. Check email_verified → 403 if false&#xa;  5. Reset fail counter&#xa;  6. Generate JWT pair (access 15m, refresh 7d)&#xa;  7. Create session (store token hashes)&#xa;  8. Update last_login&#xa;&#xa;Response: { accessToken, refreshToken, user }" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="400" y="70" width="500" height="260" as="geometry" />
        </mxCell>
        <mxCell id="af-protect-box" value="PROTECTED REQUEST&#xa;&#xa;Client → Any /api/* + Authorization: Bearer token&#xa;&#xa;auth middleware:&#xa;  1. Extract token from header&#xa;  2. Verify JWT signature&#xa;  3. Check expiration&#xa;  4. Hash token → find session&#xa;  5. Check is_revoked = false&#xa;  6. Get user from DB&#xa;  7. Attach req.user&#xa;&#xa;On 401: apiFetch() auto-retries with&#xa;tryRefreshToken() → POST /auth/refresh" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="400" y="345" width="500" height="230" as="geometry" />
        </mxCell>
        <mxCell id="af-refresh-box" value="TOKEN REFRESH&#xa;&#xa;Access token expired → 401&#xa;&#xa;apiFetch() calls tryRefreshToken():&#xa;  POST /auth/refresh { refreshToken }&#xa;&#xa;Server:&#xa;  1. Hash refresh token&#xa;  2. Find session by refresh_token_hash&#xa;  3. Check is_revoked = false&#xa;  4. Check not expired&#xa;  5. Generate new access JWT&#xa;  6. Update session&#xa;&#xa;Client retries original request&#xa;If refresh fails → handleLogout()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="400" y="590" width="500" height="260" as="geometry" />
        </mxCell>

        <!-- CLIENT ERROR HANDLING -->
        <mxCell id="ch-title" value="CLIENT: apiFetch() WRAPPER" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontStyle=1;fontColor=#2E96D4;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="50" y="710" width="250" height="25" as="geometry" />
        </mxCell>
        <mxCell id="ch-code" value="apiFetch(path, options)&#xa;  AbortController 30s timeout&#xa;  Auto-attach Authorization header&#xa;  On 401 → tryRefreshToken()&#xa;  On fail → handleLogout()&#xa;&#xa;_apiSave(path, body, method)&#xa;  Fire-and-forget with 2 retries&#xa;  Skips if !state.accessToken&#xa;  Used for all tracking dual-writes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#162030;strokeColor=#4a4a6a;fontColor=#e8e8e8;align=left;spacingLeft=10;fontFamily=Courier New;fontSize=9;" vertex="1" parent="1">
          <mxGeometry x="50" y="740" width="280" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>

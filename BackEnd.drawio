        <mxCell id="gf-streak" value="UPDATE STREAKS&#xa;&#xa;Consecutive day&#xa;increment streak&#xa;&#xa;Update best&#xa;streak record" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D45C8C;strokeColor=#a03a68;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="975" width="130" height="120" as="geometry" />
        </mxCell>
        <mxCell id="gf-achieve" value="CHECK&#xa;ACHIEVEMENTS&#xa;&#xa;For each: check&#xa;condition. If met&#xa;&amp; not unlocked:&#xa;Award badge&#xa;(+step types NEW)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2E96D4;strokeColor=#1a6ba0;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="970" width="130" height="130" as="geometry" />
        </mxCell>
        <mxCell id="gf-arrow2" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-engine" target="gf-xp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf-arrow3" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-engine" target="gf-streak"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf-arrow4" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-engine" target="gf-achieve"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf-return" value="RETURN TO CLIENT&#xa;• New Points total&#xa;• Level up if applicable&#xa;• New achievements&#xa;• Updated streaks" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#2EB896;strokeColor=#1a8870;fontColor=#ffffff;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="1140" width="250" height="100" as="geometry" />
        </mxCell>
        <mxCell id="gf-arrow5" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-xp" target="gf-return"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf-arrow6" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-streak" target="gf-return"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="gf-arrow7" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;" edge="1" parent="1" source="gf-achieve" target="gf-return"><mxGeometry relative="1" as="geometry" /></mxCell>
